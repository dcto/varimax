{
  "name": "varimax/varimax",
  "description": "Varimax The Full Stack PHP Frameworks",
  "type": "project",
  "keywords": ["php","php framework", "varimax-framework"],
  "license": "MIT",
  "prefer-stable" : true,
  "homepage": "http://www.varimax.cn",
  "version": "v2.0",
  "support": {
    "issues": "https://github.com/dcto/varimax/issues",
    "source": "https://github.com/dcto/varimax"
  },
  "authors": [
    {
      "name": "Sem.dc",
      "email": "varimaxs@gmail.com"
    }
  ],

  "require": {
    "php": ">=8.0",
    "ext-xml":"*",
    "ext-json":"*",
    "ext-curl":"*",
    "ext-bcmath": "*",
    "ext-openssl": "*",
    "ext-mbstring": "*",
    "psr/log": "1.*",
    "symfony/http-foundation": "5.*",
    "illuminate/contracts": "8.*",
    "illuminate/container": "8.*",
    "illuminate/support": "8.*",
    "illuminate/events": "8.*",
    "illuminate/database": "8.*",
    "illuminate/filesystem": "8.*",
    "illuminate/pagination": "8.*",
    "twig/twig": "3.*",
    "vlucas/phpdotenv":"5.3.*",
    "hashids/hashids": "^4.0",
    "nesbot/carbon": "2.*" 
  },

  "autoload": {
    "files": [
      "src/Bootstrap.php"
    ],
    "psr-4": {
      "VM\\": "src/"
    },
    "classmap":[
      "src/Support/Arr.php",
      "src/Support/Str.php",
      "src/Support/Facades"
    ]
  }
}
